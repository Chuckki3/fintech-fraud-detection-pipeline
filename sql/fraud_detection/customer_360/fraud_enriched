CREATE OR REPLACE TABLE `paysim-fraud-pipeline.paysim.fraud_enriched` AS
SELECT
  t.*,
  c.customer_segment,
  c.total_transactions,
  c.avg_transaction_amount,
  c.transaction_frequency

FROM `paysim-fraud-pipeline.paysim.transactions_scored_v2` t
LEFT JOIN `paysim-fraud-pipeline.paysim.customer_segments` c
ON t.nameOrig = c.customer_id;