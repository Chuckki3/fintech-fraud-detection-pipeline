CREATE OR REPLACE TABLE `paysim-fraud-pipeline.paysim.customer_360` AS
SELECT
  nameOrig AS customer_id,

  COUNT(*) AS total_transactions,
  SUM(amount) AS total_amount,
  AVG(amount) AS avg_transaction_amount,
  STDDEV(amount) AS amount_variability,

  MIN(step) AS first_transaction_step,
  MAX(step) AS last_transaction_step,

  COUNT(*) / (MAX(step) - MIN(step) + 1) AS transaction_frequency

FROM `paysim-fraud-pipeline.paysim.transactions_clean_fixed`
GROUP BY nameOrig;